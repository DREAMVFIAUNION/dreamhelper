# ═══════════════════════════════════════════════════════════
# 梦帮小助 v3.4 · 生产环境变量模板
# 复制为 .env.prod 并填写实际值
# 启动: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ═══════════════════════════════════════════════════════════

# ── 数据库 (必填) ──────────────────────────────────────────
DB_USER=dreamhelp
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT (必填, >=32字符) ───────────────────────────────────
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ── Encryption (64位hex, 32字节) ──────────────────────────
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ── Brain Core API Key (必填, >=16字符) ────────────────────
BRAIN_API_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_16

# ── LLM API Keys (至少填一个) ─────────────────────────────
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
KIMI_API_KEY=your_kimi_api_key
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ── NVIDIA NIM (免费无限量) ────────────────────────────────
NVIDIA_API_KEY=nvapi-xxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── 双脑配置 ──────────────────────────────────────────────
DUAL_BRAIN_ENABLED=true
DUAL_BRAIN_LEFT_MODEL=z-ai/glm5
DUAL_BRAIN_RIGHT_MODEL=qwen/qwen3.5-397b-a17b
DUAL_BRAIN_FUSION_MODEL=z-ai/glm5
CEREBELLUM_MODEL=moonshotai/kimi-k2.5
BRAINSTEM_MODEL=z-ai/glm5

# ── RAG + 语义记忆 (Sprint B) ──────────────────────────────
RAG_MODE=memory
EMBEDDING_PROVIDER=minimax
EMBEDDING_DIM=1536

# ── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.dreamvfia.com

# ── MinIO ────────────────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# ── Webhook ──────────────────────────────────────────────
WEBHOOK_SECRET=

# ── 意识核 (Consciousness Core) ─────────────────────────
CONSCIOUSNESS_ENABLED=true
CONSCIOUSNESS_MODEL=nvidia/nemotron-3-nano-30b-a3b
CONSCIOUSNESS_WORLD_MODEL=nvidia/cosmos-reason2-8b
# 内心独白间隔(秒), 默认900(15分钟)
CONSCIOUSNESS_THINK_INTERVAL=900

# ── GitNexus 代码智能 (Sprint C, 可选) ─────────────────
GITNEXUS_ENABLED=false
MCP_GITNEXUS=false
GITNEXUS_DEFAULT_REPO=

# ── MCP 外接工具 ───────────────────────────────────────
MCP_ENABLED=true
MCP_SEQUENTIAL_THINKING=true
MCP_FILESYSTEM=true
MCP_FILESYSTEM_ALLOWED_DIRS=/data/dreamhelp
MCP_MEMORY_GRAPH=true

# ── 监控 (Sentry, 可选) ─────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── 多渠道 (可选) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECOM_CORP_ID=
WECOM_SECRET=
WECOM_AGENT_ID=
WECOM_TOKEN=
